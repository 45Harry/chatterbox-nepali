\uc0\u2407 . \u2344 \u2350 \u2360 \u2381 \u2340 \u2375 , \u2325 \u2354 \u2375 \u2332  \u2346 \u2381 \u2352 \u2358 \u2366 \u2360 \u2344 \u2350 \u2366  \u2360 \u2381 \u2357 \u2366 \u2327 \u2340  \u2331 \u2404 \u8232 \u2408 . \u2349 \u2352 \u2381 \u2344 \u2366  \u2347 \u2366 \u2352 \u2350  \u2309 \u2344 \u2354 \u2366 \u2311 \u2344 \u2348 \u2366 \u2335  \u2346 \u2344 \u2367  \u2349 \u2352 \u2381 \u2344  \u2360 \u2325 \u2367 \u2344 \u2381 \u2331 \u2404 \u8232 \u2409 . \u2348 \u2367 \u2348 \u2367 \u2319  (BBA) \u2325 \u2379  \u2325 \u2325 \u2381 \u2359 \u2366  \u2348 \u2367 \u2361 \u2366 \u2344  \u2412  \u2348 \u2332 \u2375  \u2360 \u2369 \u2352 \u2369  \u2361 \u2369 \u2344 \u2381 \u2331 \u2404 \u8232 \u2410 . \u2360 \u2375 \u2350 \u2375 \u2360 \u2381 \u2335 \u2352 \u2325 \u2379  \u2358 \u2369 \u2354 \u2381 \u2325  \u2325 \u2367 \u2360 \u2381 \u2340 \u2366 \u2348 \u2344 \u2381 \u2342 \u2368 \u2350 \u2366  \u2340 \u2367 \u2352 \u2381 \u2344  \u2350 \u2367 \u2354 \u2381 \u2331 \u2404 \u8232 \u2411 . \u2354 \u2366 \u2311 \u2348 \u2381 \u2352 \u2375 \u2352 \u2368  \u2325 \u2366 \u2352 \u2381 \u2337  \u2361 \u2352 \u2366 \u2319 \u2350 \u2366  \u2332 \u2352 \u2367 \u2357 \u2366 \u2344 \u2366  \u2354 \u2366 \u2327 \u2381 \u2331 \u2404 \u8232 \u2412 . \u2346 \u2381 \u2352 \u2351 \u2379 \u2327 \u2366 \u2340 \u2381 \u2350 \u2325  \u2346 \u2352 \u2368 \u2325 \u2381 \u2359 \u2366  (Practical Exam) \u2325 \u2379  \u2340 \u2366 \u2354 \u2367 \u2325 \u2366  \u2310 \u2351 \u2379 \u2404 \u8232 \u2413 . \u2325 \u2354 \u2375 \u2332 \u2325 \u2379  \u2357 \u2366 \u2311 \u2347 \u2366 \u2311  \u2346 \u2366 \u2360 \u2357 \u2352 \u2381 \u2337  \u2357 \u2367 \u2342 \u2381 \u2351 \u2366 \u2352 \u2381 \u2341 \u2368  \u2358 \u2366 \u2326 \u2366 \u2350 \u2366  \u2360 \u2379 \u2343 \u2381 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2414 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2309 \u2360 \u2366 \u2311 \u2344 \u2350 \u2375 \u2344 \u2381 \u2335  \u2348 \u2369 \u2333 \u2366 \u2313 \u2344 \u2375  \u2309 \u2344 \u2381 \u2340 \u2367 \u2350  \u2350 \u2367 \u2340 \u2367  \u2310 \u2332  \u2361 \u2379 \u2404 \u8232 \u2415 . \u2325 \u2354 \u2375 \u2332  \u2337 \u2381 \u2352 \u2375 \u2360  \u2348 \u2367 \u2344 \u2366  \u2325 \u2325 \u2381 \u2359 \u2366 \u2350 \u2366  \u2348 \u2360 \u2381 \u2344  \u2346 \u2366 \u2311 \u2305 \u2342 \u2376 \u2344 \u2404 \u8232 \u2407 \u2406 . \u2331 \u2366 \u2340 \u2381 \u2352 \u2357 \u2371 \u2340 \u2381 \u2340 \u2367 \u2325 \u2379  \u2344 \u2340 \u2367 \u2332 \u2366  \u2346 \u2381 \u2352 \u2325 \u2366 \u2358 \u2367 \u2340  \u2349 \u2351 \u2379 \u2404 \u8232 \u2407 \u2407 . \u2335 \u2381 \u2352 \u2366 \u2344 \u2381 \u2360 \u2325 \u2381 \u2352 \u2367 \u2346 \u2381 \u2335  (Transcript) \u2354 \u2367 \u2344  \u2351 \u2369 \u2344 \u2367 \u2349 \u2352 \u2381 \u2360 \u2367 \u2335 \u2368  \u2332 \u2366 \u2344 \u2369 \u2346 \u2352 \u2381 \u2331 \u2404 \u8232 \u2407 \u2408 . \u2310 \u2332 \u2325 \u2379  \u2325 \u2325 \u2381 \u2359 \u2366  \u2352 \u2342 \u2381 \u2342  \u2349 \u2319 \u2325 \u2379  \u2331 \u2404 \u8232 \u2407 \u2409 . \u2346 \u2352 \u2367 \u2330 \u2351 \u2346 \u2340 \u2381 \u2352  \u2344 \u2357 \u2368 \u2325 \u2352 \u2339  \u2327 \u2352 \u2381 \u2344 \u2369 \u2346 \u2352 \u2381 \u2344 \u2375  \u2349 \u2319 \u2331 \u2404 \u8232 \u2407 \u2410 . \u2325 \u2354 \u2375 \u2332  \u2325 \u2381 \u2351 \u2366 \u2344 \u2381 \u2335 \u2367 \u2344 \u2350 \u2366  \u2360 \u2381 \u2357 \u2366 \u2360 \u2381 \u2341 \u2381 \u2351 \u2357 \u2352 \u2381 \u2343 \u2325  \u2326 \u2366 \u2344 \u2366  \u2346 \u2366 \u2311 \u2344 \u2381 \u2331 \u2404 \u8232 \u2407 \u2411 . \u2346 \u2381 \u2352 \u2379 \u2332 \u2375 \u2325 \u2381 \u2335  \u2357 \u2352 \u2381 \u2325 \u2325 \u2379  \u2354 \u2366 \u2327 \u2367  \u2360 \u2350 \u2370 \u2361  \u2348 \u2344 \u2366 \u2313 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2407 \u2412 . \u2351 \u2379  \u2357 \u2367 \u2359 \u2351 \u2325 \u2379  \u2325 \u2325 \u2381 \u2359 \u2366  \u2325 \u2379 \u2336 \u2366  \u2344 \u2350 \u2381 \u2348 \u2352  \u2409 \u2406 \u2408  \u2350 \u2366  \u2361 \u2369 \u2344 \u2381 \u2331 \u2404 \u8232 \u2407 \u2413 . \u2325 \u2379 \u2309 \u2352 \u2381 \u2337 \u2367 \u2344 \u2375 \u2335 \u2352  \u2360 \u2352 \u2360 \u2305 \u2327  \u2349 \u2375 \u2335 \u2381 \u2344  \u2360 \u2350 \u2351  \u2354 \u2367 \u2344 \u2369 \u2346 \u2352 \u2381 \u2331 \u2404 \u8232 \u2407 \u2414 . \u2310 \u2344 \u2381 \u2340 \u2352 \u2367 \u2325  \u2346 \u2352 \u2368 \u2325 \u2381 \u2359 \u2366  (Internal Exam) \u2309 \u2344 \u2367 \u2357 \u2366 \u2352 \u2381 \u2351  \u2331 \u2404 \u8232 \u2407 \u2415 . \u2325 \u2354 \u2375 \u2332  \u2348 \u2360  \u2330 \u2338 \u2381 \u2344  \u2346 \u2366 \u2360  \u2342 \u2375 \u2326 \u2366 \u2313 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 \u2404 \u8232 \u2408 \u2406 . \u2358 \u2376 \u2325 \u2381 \u2359 \u2367 \u2325  \u2349 \u2381 \u2352 \u2350 \u2339  (Tour) \u2325 \u2379  \u2354 \u2366 \u2327 \u2367  \u2344 \u2366 \u2350  \u2342 \u2352 \u2381 \u2340 \u2366  \u2327 \u2352 \u2381 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2408 \u2407 . \u2354 \u2381 \u2351 \u2366 \u2348 \u2350 \u2366  \u2313 \u2346 \u2325 \u2352 \u2339 \u2361 \u2352 \u2370  \u2361 \u2379 \u2360 \u2367 \u2351 \u2366 \u2352 \u2346 \u2370 \u2352 \u2381 \u2357 \u2325  \u2330 \u2354 \u2366 \u2313 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2408 \u2408 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2361 \u2366 \u2332 \u2367 \u2352 \u2368  \u2413 \u2411  \u2346 \u2381 \u2352 \u2340 \u2367 \u2358 \u2340  \u2346 \u2369 \u2327 \u2375 \u2325 \u2379  \u2331 \u2376 \u2344 \u2404 \u8232 \u2408 \u2409 . \u2323 \u2352 \u2367 \u2319 \u2344 \u2381 \u2335 \u2375 \u2360 \u2344  \u2325 \u2366 \u2352 \u2381 \u2351 \u2325 \u2381 \u2352 \u2350 \u2350 \u2366  \u2313 \u2346 \u2360 \u2381 \u2341 \u2367 \u2340  \u2361 \u2369 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 \u2404 \u8232 \u2408 \u2410 . \u2325 \u2354 \u2375 \u2332 \u2325 \u2379  \u2344 \u2367 \u2351 \u2350  \u2357 \u2367 \u2346 \u2352 \u2367 \u2340  \u2325 \u2366 \u2350  \u2327 \u2352 \u2375 \u2350 \u2366  \u2344 \u2367 \u2359 \u2381 \u2325 \u2366 \u2360 \u2344  \u2327 \u2352 \u2367 \u2344 \u2375 \u2331 \u2404 \u8232 \u2408 \u2411 . \u2346 \u2370 \u2352 \u2325  \u2346 \u2352 \u2368 \u2325 \u2381 \u2359 \u2366  (Re-exam) \u2325 \u2379  \u2347 \u2366 \u2352 \u2350  \u2326 \u2369 \u2354 \u2367 \u2360 \u2325 \u2381 \u2351 \u2379 \u2404 \u8232 \u2408 \u2412 . \u2360 \u2381 \u2344 \u2366 \u2340 \u2325  \u2340 \u2361 \u2325 \u2379  \u2349 \u2352 \u2381 \u2344 \u2366  \u2325 \u2361 \u2367 \u2354 \u2375  \u2326 \u2369 \u2354 \u2381 \u2331 ?\u8232 \u2408 \u2413 . \u2325 \u2371 \u2346 \u2351 \u2366  \u2310 \u2347 \u2381 \u2344 \u2379  \u2360 \u2357 \u2366 \u2352 \u2368  \u2360 \u2366 \u2343 \u2344  \u2346 \u2366 \u2352 \u2381 \u2325 \u2367 \u2329 \u2350 \u2366  \u2352 \u2366 \u2326 \u2381 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2408 \u2414 . \u2325 \u2354 \u2375 \u2332  \u2361 \u2366 \u2340 \u2366 \u2349 \u2367 \u2340 \u2381 \u2352  \u2361 \u2379 \u2361 \u2354 \u2381 \u2354 \u2366  \u2344 \u2327 \u2352 \u2381 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 \u2404 \u8232 \u2408 \u2415 . \u2346 \u2370 \u2352 \u2381 \u2357  \u2357 \u2367 \u2342 \u2381 \u2351 \u2366 \u2352 \u2381 \u2341 \u2368  \u2360 \u2350 \u2366 \u2332  (Alumni) \u2350 \u2366  \u2332 \u2379 \u2337 \u2367 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2409 \u2406 . \u2310 \u2332  \u2325 \u2381 \u2351 \u2366 \u2350 \u2381 \u2346 \u2360  \u2346 \u2381 \u2352 \u2350 \u2369 \u2326  \u2310 \u2313 \u2344 \u2369 \u2349 \u2319 \u2325 \u2379  \u2331 \u2376 \u2344 \u2404 \u8232 \u2409 \u2407 . \u2346 \u2381 \u2352 \u2350 \u2366 \u2339  \u2346 \u2340 \u2381 \u2352  \u2360 \u2325 \u2381 \u2325 \u2354  \u2344 \u2376  \u2354 \u2381 \u2351 \u2366 \u2313 \u2344 \u2369 \u2346 \u2352 \u2381 \u2331 \u2404 \u8232 \u2409 \u2408 . \u2311 \u2344 \u2381 \u2335 \u2352 \u2381 \u2344 \u2360 \u2367 \u2346 \u2325 \u2379  \u2354 \u2366 \u2327 \u2367  \u2325 \u2354 \u2375 \u2332 \u2354 \u2375  \u2360 \u2367 \u2347 \u2366 \u2352 \u2367 \u2360  \u2346 \u2340 \u2381 \u2352  \u2342 \u2367 \u2344 \u2381 \u2331 \u2404 \u8232 \u2409 \u2409 . \u2360 \u2381 \u2357 \u2366 \u2327 \u2340  \u2340 \u2341 \u2366  \u2348 \u2367 \u2342 \u2366 \u2312  \u2325 \u2366 \u2352 \u2381 \u2351 \u2325 \u2381 \u2352 \u2350 \u2325 \u2379  \u2340 \u2351 \u2366 \u2352 \u2368  \u2361 \u2369 \u2305 \u2342 \u2376 \u2331 \u2404 \u8232 \u2409 \u2410 . \u2351 \u2379  \u2360 \u2375 \u2350 \u2375 \u2360 \u2381 \u2335 \u2352 \u2350 \u2366  \u2411  \u2357 \u2335 \u2366  \u2357 \u2367 \u2359 \u2351  \u2346 \u2338 \u2381 \u2344 \u2369 \u2346 \u2352 \u2381 \u2331 \u2404 \u8232 \u2409 \u2411 . \u2360 \u2379 \u2343 \u2346 \u2369 \u2331  \u2325 \u2325 \u2381 \u2359  (Information Desk) \u2342 \u2366 \u2351 \u2366 \u2305 \u2340 \u2352 \u2381 \u2347  \u2331 \u2404 \u8232 \u2409 \u2412 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2311 \u2350 \u2375 \u2354 \u2350 \u2366  \u2344 \u2379 \u2335  \u2346 \u2336 \u2366 \u2311 \u2342 \u2367 \u2319 \u2325 \u2379  \u2331 \u2369 \u2404 \u8232 \u2409 \u2413 . \u2346 \u2381 \u2352 \u2375 \u2332 \u2375 \u2344 \u2381 \u2335 \u2375 \u2360 \u2344  \u2342 \u2367 \u2344  \u2309 \u2344 \u2367 \u2357 \u2366 \u2352 \u2381 \u2351  \u2331 \u2404 \u8232 \u2409 \u2414 . \u2351 \u2379  \u2347 \u2352 \u2381 \u2350  \u2349 \u2352 \u2375 \u2352  \u2357 \u2367 \u2349 \u2366 \u2327 \u2350 \u2366  \u2348 \u2369 \u2333 \u2366 \u2313 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 \u2404 \u8232 \u2409 \u2415 . \u2325 \u2354 \u2375 \u2332 \u2325 \u2379  \u2347 \u2375 \u2360 \u2348 \u2369 \u2325  \u2346 \u2375 \u2332 \u2350 \u2366  \u2360 \u2370 \u2330 \u2344 \u2366  \u2361 \u2375 \u2352 \u2381 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 \u2404 \u8232 \u2410 \u2406 . \u2357 \u2367 \u2342 \u2381 \u2351 \u2366 \u2352 \u2381 \u2341 \u2368  \u2325 \u2354 \u2381 \u2351 \u2366 \u2339 \u2325 \u2366 \u2352 \u2368  \u2325 \u2379 \u2359 \u2350 \u2366  \u2360 \u2361 \u2351 \u2379 \u2327  \u2327 \u2352 \u2381 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2410 \u2407 . \u2346 \u2369 \u2360 \u2381 \u2340 \u2325 \u2366 \u2354 \u2351 \u2350 \u2366  \u2358 \u2366 \u2344 \u2381 \u2340  \u2352 \u2361 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 \u2404 \u8232 \u2410 \u2408 . \u2349 \u2352 \u2381 \u2344 \u2366  \u2352 \u2342 \u2381 \u2342  \u2327 \u2352 \u2381 \u2344  \u2344 \u2367 \u2357 \u2375 \u2342 \u2344  \u2342 \u2367 \u2344 \u2369 \u2346 \u2352 \u2381 \u2331 \u2404 \u8232 \u2410 \u2409 . \u2352 \u2367 \u2332 \u2354 \u2381 \u2335  \u2361 \u2375 \u2352 \u2381 \u2344  \u2357 \u2375 \u2348 \u2360 \u2366 \u2311 \u2335  \u2330 \u2375 \u2325  \u2327 \u2352 \u2381 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2410 \u2410 . \u2360 \u2366 \u2341 \u2368 \u2349 \u2366 \u2311 \u2360 \u2305 \u2327  \u2350 \u2367 \u2354 \u2375 \u2352  \u2346 \u2338 \u2381 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2410 \u2411 . \u2325 \u2354 \u2375 \u2332 \u2325 \u2379  \u2346 \u2381 \u2352 \u2340 \u2367 \u2359 \u2381 \u2336 \u2366  \u2332 \u2379 \u2327 \u2366 \u2313 \u2344 \u2369  \u2361 \u2366 \u2350 \u2381 \u2352 \u2379  \u2342 \u2366 \u2351 \u2367 \u2340 \u2381 \u2357  \u2361 \u2379 \u2404 \u8232 \u2410 \u2412 . \u2325 \u2369 \u2344 \u2376  \u2360 \u2350 \u2360 \u2381 \u2351 \u2366  \u2346 \u2352 \u2375  \u2325 \u2366 \u2313 \u2344 \u2381 \u2360 \u2367 \u2354 \u2352 \u2354 \u2366 \u2312  \u2349 \u2375 \u2335 \u2381 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2410 \u2413 . \u2346 \u2352 \u2368 \u2325 \u2381 \u2359 \u2366  \u2361 \u2354 \u2350 \u2366  \u2350 \u2379 \u2348 \u2366 \u2311 \u2354  \u2354 \u2376 \u2332 \u2366 \u2344  \u2346 \u2366 \u2311 \u2305 \u2342 \u2376 \u2344 \u2404 \u8232 \u2410 \u2414 . \u2351 \u2379  \u2325 \u2379 \u2352 \u2381 \u2360  \u2410  \u2357 \u2352 \u2381 \u2359 \u2325 \u2379  \u2361 \u2369 \u2344 \u2381 \u2331 \u2404 \u8232 \u2410 \u2415 . \u2343 \u2344 \u2381 \u2351 \u2357 \u2366 \u2342 , \u2352 \u2366 \u2350 \u2381 \u2352 \u2379 \u2360 \u2305 \u2327  \u2346 \u2338 \u2381 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 \u2404 \u8232 \u2411 \u2406 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2349 \u2357 \u2367 \u2359 \u2381 \u2351  \u2313 \u2332 \u2381 \u2332 \u2381 \u2357 \u2354  \u2352 \u2361 \u2379 \u2360 \u2381 \u2404 \
