\f2\i\b0\fs24 \cf0 (\uc0\u2327 \u2381 \u2352 \u2366 \u2361 \u2325  \u2360 \u2375 \u2357 \u2366 , \u2335 \u2375 \u2354 \u2352  \u2352  \u2360 \u2379 \u2343 \u2346 \u2369 \u2331  \u2325 \u2325 \u2381 \u2359 \u2325 \u2366  \u2354 \u2366 \u2327 \u2367 )
\f0\i0 \
\uc0\u2407 . \u2344 \u2350 \u2360 \u2381 \u2325 \u2366 \u2352 ! [\u2348 \u2376 \u2306 \u2325 \u2325 \u2379  \u2344 \u2366 \u2350 ] \u2350 \u2366  \u2351 \u2361 \u2366 \u2305 \u2354 \u2366 \u2312  \u2360 \u2381 \u2357 \u2366 \u2327 \u2340  \u2331 \u2404 \u8232 \u2408 . \u2361 \u2332 \u2369 \u2352 , \u2350  \u2340 \u2346 \u2366 \u2311 \u2305 \u2354 \u2366 \u2312  \u2325 \u2360 \u2352 \u2368  \u2360 \u2361 \u2351 \u2379 \u2327  \u2327 \u2352 \u2381 \u2344  \u2360 \u2325 \u2381 \u2331 \u2369 ?\u8232 \u2409 . \u2326 \u2366 \u2340 \u2366  \u2326 \u2379 \u2354 \u2381 \u2344 \u2325 \u2379  \u2354 \u2366 \u2327 \u2367  \u2325 \u2371 \u2346 \u2351 \u2366  \u2351 \u2379  \u2347 \u2366 \u2352 \u2350  \u2349 \u2352 \u2381 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2410 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2346 \u2352 \u2367 \u2330 \u2351 \u2346 \u2340 \u2381 \u2352  (\u2344 \u2366 \u2327 \u2352 \u2367 \u2325 \u2340 \u2366 ) \u2325 \u2379  \u2347 \u2379 \u2335 \u2379 \u2325 \u2346 \u2368  \u2360 \u2366 \u2341 \u2350 \u2366  \u2331 ?\u8232 \u2411 . \u2344 \u2327 \u2342  \u2332 \u2350 \u2381 \u2350 \u2366  \u2327 \u2352 \u2381 \u2344  \u2325 \u2371 \u2346 \u2351 \u2366  \u2349 \u2380 \u2330 \u2352  \u2349 \u2352 \u2381 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2412 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2330 \u2375 \u2325  \u2360 \u2366 \u2335 \u2381 \u2344  \u2325 \u2371 \u2346 \u2351 \u2366  \u2408  \u2344 \u2350 \u2381 \u2348 \u2352  \u2325 \u2366 \u2313 \u2344 \u2381 \u2335 \u2352 \u2350 \u2366  \u2332 \u2366 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 \u2404 \u8232 \u2413 . \u2325 \u2375  \u2361 \u2332 \u2369 \u2352 \u2354 \u2375  \u2337 \u2367 \u2332 \u2367 \u2335 \u2354  \u2348 \u2376 \u2306 \u2325 \u2367 \u2329  \u2360 \u2375 \u2357 \u2366  \u2354 \u2367 \u2344 \u2369 \u2349 \u2319 \u2325 \u2379  \u2331 ?\u8232 \u2414 . \u2319 \u2335 \u2368 \u2319 \u2350  \u2325 \u2366 \u2352 \u2381 \u2337  \u2354 \u2367 \u2344 \u2325 \u2379  \u2354 \u2366 \u2327 \u2367  \u2344 \u2366 \u2327 \u2352 \u2367 \u2325 \u2340 \u2366  \u2342 \u2375 \u2326 \u2366 \u2313 \u2344 \u2369 \u2346 \u2352 \u2381 \u2344 \u2375  \u2361 \u2369 \u2344 \u2381 \u2331 \u2404 \u8232 \u2415 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2361 \u2360 \u2381 \u2340 \u2366 \u2325 \u2381 \u2359 \u2352  \u2350 \u2367 \u2354 \u2375 \u2344 , \u2325 \u2371 \u2346 \u2351 \u2366  \u2346 \u2369 \u2344 \u2307  \u2346 \u2381 \u2352 \u2351 \u2366 \u2360  \u2327 \u2352 \u2381 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2407 \u2406 . \u2350 \u2369 \u2342 \u2381 \u2342 \u2340 \u2368  \u2326 \u2366 \u2340 \u2366  (Fixed Deposit) \u2325 \u2379  \u2348 \u2381 \u2351 \u2366 \u2332 \u2342 \u2352  \u2309 \u2361 \u2367 \u2354 \u2375  \u2407 \u2406  \u2346 \u2381 \u2352 \u2340 \u2367 \u2358 \u2340  \u2331 \u2404 \u8232 \u2407 \u2407 . \u2315 \u2339  \u2358 \u2366 \u2326 \u2366 \u2325 \u2366  \u2354 \u2366 \u2327 \u2367  \u2325 \u2371 \u2346 \u2351 \u2366  \u2350 \u2366 \u2341 \u2367 \u2354 \u2381 \u2354 \u2379  \u2340 \u2354 \u2366 \u2350 \u2366  \u2332 \u2366 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2407 \u2408 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2350 \u2379 \u2348 \u2366 \u2311 \u2354  \u2348 \u2376 \u2306 \u2325 \u2367 \u2329 \u2325 \u2379  \u2346 \u2366 \u2360 \u2357 \u2352 \u2381 \u2337  \u2352 \u2367 \u2360 \u2375 \u2335  \u2327 \u2352 \u2367 \u2342 \u2367 \u2313 \u2305 \u2354 \u2366 \u2404 \u8232 \u2407 \u2409 . \u2325 \u2371 \u2346 \u2351 \u2366  \u2354 \u2366 \u2311 \u2344 \u2350 \u2366  \u2348 \u2360 \u2381 \u2344 \u2369 \u2349 \u2312  \u2360 \u2361 \u2351 \u2379 \u2327  \u2327 \u2352 \u2367 \u2342 \u2367 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2407 \u2410 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2326 \u2366 \u2340 \u2366  \u2310 \u2332 \u2376  \u2360 \u2325 \u2381 \u2352 \u2367 \u2351  (Active) \u2361 \u2369 \u2344 \u2375 \u2331 \u2404 \u8232 \u2407 \u2411 . \u2325 \u2375 \u2357 \u2366 \u2312 \u2360 \u2368  (KYC) \u2309 \u2346 \u2337 \u2375 \u2335  \u2327 \u2352 \u2381 \u2344 \u2325 \u2379  \u2354 \u2366 \u2327 \u2367  \u2361 \u2366 \u2354 \u2360 \u2366 \u2354 \u2376  \u2326 \u2367 \u2330 \u2375 \u2325 \u2379  \u2347 \u2379 \u2335 \u2379  \u2330 \u2366 \u2361 \u2367 \u2344 \u2381 \u2331 \u2404 \u8232 \u2407 \u2412 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2326 \u2366 \u2340 \u2366 \u2350 \u2366  \u2346 \u2352 \u2381 \u2351 \u2366 \u2346 \u2381 \u2340  \u2350 \u2380 \u2332 \u2381 \u2342 \u2366 \u2340  (Balance) \u2331 \u2376 \u2344 \u2404 \u8232 \u2407 \u2413 . \u2330 \u2375 \u2325  \u2325 \u2381 \u2354 \u2367 \u2351 \u2352 \u2367 \u2329  \u2361 \u2369 \u2344  \u2342 \u2369 \u2312  \u2342 \u2367 \u2344  \u2354 \u2366 \u2327 \u2381 \u2344 \u2375 \u2331 \u2404 \u8232 \u2407 \u2414 . \u2360 \u2381 \u2335 \u2375 \u2335 \u2350 \u2375 \u2344 \u2381 \u2335  \u2346 \u2381 \u2352 \u2367 \u2344 \u2381 \u2335  \u2327 \u2352 \u2381 \u2344  \u2325 \u2340 \u2367  \u2360 \u2350 \u2351 \u2325 \u2379  \u2357 \u2367 \u2357 \u2352 \u2339  \u2330 \u2366 \u2361 \u2367 \u2344 \u2381 \u2331 ?\u8232 \u2407 \u2415 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2327 \u2369 \u2344 \u2366 \u2360 \u2379  \u2361 \u2366 \u2350 \u2368 \u2354 \u2375  \u2335 \u2367 \u2346 \u2381 \u2351 \u2380 \u2305 , \u2331 \u2367 \u2335 \u2381 \u2335 \u2376  \u2360 \u2350 \u2366 \u2343 \u2366 \u2344  \u2327 \u2352 \u2381 \u2344 \u2375 \u2331 \u2380 \u2305 \u2404 \u8232 \u2408 \u2406 . \u2357 \u2367 \u2342 \u2375 \u2358 \u2368  \u2350 \u2369 \u2342 \u2381 \u2352 \u2366  \u2360 \u2366 \u2335 \u2381 \u2344 \u2325 \u2379  \u2354 \u2366 \u2327 \u2367  \u2346 \u2366 \u2360 \u2346 \u2379 \u2352 \u2381 \u2335  \u2309 \u2344 \u2367 \u2357 \u2366 \u2352 \u2381 \u2351  \u2331 \u2404 \u8232 \u2408 \u2407 . \u2354 \u2325 \u2352  \u2360 \u2369 \u2357 \u2367 \u2343 \u2366 \u2325 \u2379  \u2354 \u2366 \u2327 \u2367  \u2350 \u2381 \u2351 \u2366 \u2344 \u2375 \u2332 \u2352  \u2360 \u2352 \u2360 \u2305 \u2327  \u2325 \u2369 \u2352 \u2366  \u2327 \u2352 \u2381 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2408 \u2408 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2326 \u2366 \u2340 \u2366  \u2344 \u2350 \u2381 \u2348 \u2352  \u2319 \u2325 \u2346 \u2335 \u2325  \u2352 \u2369 \u2332 \u2369  \u2327 \u2352 \u2381 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 \u2404 \u8232 \u2408 \u2409 . \u2325 \u2371 \u2346 \u2351 \u2366  \u2351 \u2361 \u2366 \u2305  \u2324 \u2306 \u2336 \u2366 \u2331 \u2366 \u2346  \u2354 \u2327 \u2366 \u2313 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2408 \u2410 . \u2344 \u2351 \u2366 \u2305  \u2330 \u2375 \u2325 \u2348 \u2369 \u2325 \u2325 \u2379  \u2354 \u2366 \u2327 \u2367  \u2344 \u2367 \u2357 \u2375 \u2342 \u2344  \u2342 \u2367 \u2344 \u2369 \u2346 \u2352 \u2381 \u2331 \u2404 \u8232 \u2408 \u2411 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2346 \u2376 \u2360 \u2366  \u2360 \u2369 \u2352 \u2325 \u2381 \u2359 \u2367 \u2340  \u2352 \u2370 \u2346 \u2350 \u2366  \u2335 \u2381 \u2352 \u2366 \u2344 \u2381 \u2360 \u2347 \u2352  \u2349 \u2351 \u2379 \u2404 \u8232 \u2408 \u2412 . \u2325 \u2375  \u2361 \u2332 \u2369 \u2352 \u2354 \u2366 \u2312  \u2325 \u2381 \u2352 \u2375 \u2337 \u2367 \u2335  \u2325 \u2366 \u2352 \u2381 \u2337 \u2325 \u2379  \u2348 \u2366 \u2352 \u2375 \u2350 \u2366  \u2332 \u2366 \u2344 \u2325 \u2366 \u2352 \u2368  \u2330 \u2366 \u2361 \u2367 \u2319 \u2325 \u2379  \u2361 \u2379 ?\u8232 \u2408 \u2413 . \u2357 \u2371 \u2342 \u2381 \u2343 \u2349 \u2340 \u2381 \u2340 \u2366  \u2354 \u2367 \u2344  \u2310 \u2313 \u2344 \u2369 \u2349 \u2319 \u2325 \u2379  \u2361 \u2379 ? \u2325 \u2371 \u2346 \u2351 \u2366  \u2351 \u2361 \u2366 \u2305  \u2348 \u2360 \u2381 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2408 \u2414 . \u2311 \u2344 \u2381 \u2335 \u2352 \u2344 \u2375 \u2335  \u2348 \u2376 \u2306 \u2325 \u2367 \u2329  \u2346 \u2381 \u2352 \u2351 \u2379 \u2327  \u2327 \u2352 \u2381 \u2344  \u2343 \u2375 \u2352 \u2376  \u2360 \u2332 \u2367 \u2354 \u2379  \u2331 \u2404 \u8232 \u2408 \u2415 . \u2351 \u2379  \u2309 \u2347 \u2352  \u2360 \u2368 \u2350 \u2367 \u2340  \u2309 \u2357 \u2343 \u2367 \u2325 \u2379  \u2354 \u2366 \u2327 \u2367  \u2350 \u2366 \u2340 \u2381 \u2352  \u2361 \u2379 \u2404 \u8232 \u2409 \u2406 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2325 \u2366 \u2352 \u2379 \u2348 \u2366 \u2352 \u2325 \u2379  \u2350 \u2381 \u2351 \u2366 \u2360 \u2375 \u2332  \u2350 \u2379 \u2348 \u2366 \u2311 \u2354 \u2350 \u2366  \u2310 \u2351 \u2379 ?\u8232 \u2409 \u2407 . \u2325 \u2371 \u2346 \u2351 \u2366  \u2358 \u2366 \u2344 \u2381 \u2340  \u2349 \u2312  \u2346 \u2366 \u2354 \u2379  \u2346 \u2352 \u2381 \u2326 \u2367 \u2344 \u2369 \u2361 \u2379 \u2360 \u2381 \u2404 \u8232 \u2409 \u2408 . \u2411  \u2354 \u2366 \u2326 \u2349 \u2344 \u2381 \u2342 \u2366  \u2350 \u2366 \u2341 \u2367 \u2325 \u2379  \u2325 \u2366 \u2352 \u2379 \u2348 \u2366 \u2352 \u2350 \u2366  \u2360 \u2381 \u2352 \u2379 \u2340  \u2326 \u2369 \u2354 \u2366 \u2313 \u2344 \u2369 \u2346 \u2352 \u2381 \u2331 \u2404 \u8232 \u2409 \u2409 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2319 \u2335 \u2368 \u2319 \u2350  \u2346 \u2367 \u2344  \u2325 \u2379 \u2337  \u2327 \u2379 \u2346 \u2381 \u2351  \u2352 \u2366 \u2326 \u2381 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 \u2404 \u8232 \u2409 \u2410 . \u2310 \u2332  \u2360 \u2367 \u2360 \u2381 \u2335 \u2350  \u2309 \u2354 \u2367  \u2338 \u2367 \u2354 \u2379  \u2330 \u2354 \u2367 \u2352 \u2361 \u2375 \u2325 \u2379  \u2331 , \u2350 \u2366 \u2347  \u2327 \u2352 \u2381 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 \u2404 \u8232 \u2409 \u2411 . \u2348 \u2376 \u2306 \u2325 \u2367 \u2329  \u2360 \u2350 \u2351  \u2409  \u2348 \u2332 \u2375 \u2360 \u2350 \u2381 \u2350  \u2350 \u2366 \u2340 \u2381 \u2352  \u2361 \u2379 \u2404 \u8232 \u2409 \u2412 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2360 \u2350 \u2360 \u2381 \u2351 \u2366  \u2348 \u2369 \u2333 \u2375 \u2305 , \u2350  \u2360 \u2350 \u2381 \u2348 \u2344 \u2381 \u2343 \u2367 \u2340  \u2358 \u2366 \u2326 \u2366 \u2350 \u2366  \u2325 \u2369 \u2352 \u2366  \u2327 \u2352 \u2381 \u2331 \u2369 \u2404 \u8232 \u2409 \u2413 . \u2325 \u2375  \u2361 \u2332 \u2369 \u2352 \u2354 \u2375  \u2337 \u2367 \u2350 \u2381 \u2351 \u2366 \u2335  (Demat) \u2326 \u2366 \u2340 \u2366  \u2326 \u2379 \u2354 \u2381 \u2344 \u2369 \u2349 \u2319 \u2325 \u2379  \u2331 ?\u8232 \u2409 \u2414 . \u2348 \u2367 \u2342 \u2366 \u2325 \u2379  \u2342 \u2367 \u2344 \u2350 \u2366  \u2346 \u2344 \u2367  \u2361 \u2366 \u2350 \u2381 \u2352 \u2379  \u2337 \u2367 \u2332 \u2367 \u2335 \u2354  \u2360 \u2375 \u2357 \u2366  \u2330 \u2366 \u2354 \u2369  \u2352 \u2361 \u2344 \u2381 \u2331 \u2404 \u8232 \u2409 \u2415 . \u2358 \u2376 \u2325 \u2381 \u2359 \u2367 \u2325  \u2325 \u2352 \u2381 \u2332 \u2366 \u2325 \u2379  \u2354 \u2366 \u2327 \u2367  \u2346 \u2381 \u2352 \u2325 \u2381 \u2352 \u2367 \u2351 \u2366  \u2309 \u2354 \u2367  \u2354 \u2366 \u2350 \u2379  \u2361 \u2369 \u2344  \u2360 \u2325 \u2381 \u2331 \u2404 \u8232 \u2410 \u2406 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2346 \u2369 \u2352 \u2366 \u2344 \u2379  \u2325 \u2366 \u2352 \u2381 \u2337  \u2350 \u2381 \u2351 \u2366 \u2342  \u2360 \u2325 \u2367 \u2319 \u2325 \u2379  \u2331 , \u2344 \u2351 \u2366 \u2305  \u2348 \u2344 \u2366 \u2313 \u2344 \u2369 \u2346 \u2352 \u2381 \u2331 \u2404 \u8232 \u2410 \u2407 . \u2352 \u2325 \u2350  \u2327 \u2344 \u2375 \u2352  \u2350 \u2366 \u2340 \u2381 \u2352  \u2325 \u2366 \u2313 \u2344 \u2381 \u2335 \u2352  \u2331 \u2379 \u2337 \u2381 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 \u2404 \u8232 \u2410 \u2408 . \u2360 \u2369 \u2344  \u2325 \u2352 \u2381 \u2332 \u2366 \u2325 \u2379  \u2354 \u2366 \u2327 \u2367  \u2349 \u2381 \u2351 \u2366 \u2354 \u2369 \u2319 \u2335 \u2352  \u2310 \u2313 \u2305 \u2342 \u2376  \u2361 \u2369 \u2344 \u2369 \u2361 \u2369 \u2344 \u2381 \u2331 \u2404 \u8232 \u2410 \u2409 . \u2360 \u2306 \u2351 \u2369 \u2325 \u2381 \u2340  \u2326 \u2366 \u2340 \u2366  (Joint Account) \u2326 \u2379 \u2354 \u2381 \u2344  \u2342 \u2369 \u2357 \u2376  \u2332 \u2344 \u2366  \u2313 \u2346 \u2360 \u2381 \u2341 \u2367 \u2340  \u2361 \u2369 \u2344 \u2369 \u2346 \u2352 \u2381 \u2331 \u2404 \u8232 \u2410 \u2410 . \u2361 \u2332 \u2369 \u2352 \u2354 \u2366 \u2312  \u2330 \u2367 \u2351 \u2366  \u2357 \u2366  \u2346 \u2366 \u2344 \u2368  \u2325 \u2375 \u2361 \u2368  \u2354 \u2381 \u2351 \u2366 \u2313 \u2305 ?\u8232 \u2410 \u2411 . \u2325 \u2371 \u2346 \u2351 \u2366  \u2350 \u2366 \u2360 \u2381 \u2325  \u2354 \u2327 \u2366 \u2319 \u2352  \u2350 \u2366 \u2340 \u2381 \u2352  \u2346 \u2381 \u2352 \u2357 \u2375 \u2358  \u2327 \u2352 \u2381 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 \u2404 \u8232 \u2410 \u2412 . \u2351 \u2379  \u2350 \u2375 \u2360 \u2367 \u2344 \u2348 \u2366 \u2335  \u2310 \u2347 \u2376 \u2305  \u2346 \u2376 \u2360 \u2366  \u2332 \u2350 \u2381 \u2350 \u2366  \u2327 \u2352 \u2381 \u2344  \u2360 \u2325 \u2367 \u2344 \u2381 \u2331 \u2404 \u8232 \u2410 \u2413 . \u2348 \u2376 \u2306 \u2325 \u2325 \u2379  \u2344 \u2367 \u2351 \u2350  \u2309 \u2344 \u2369 \u2360 \u2366 \u2352  \u2351 \u2379  \u2325 \u2366 \u2350  \u2327 \u2352 \u2381 \u2344  \u2350 \u2367 \u2354 \u2381 \u2342 \u2376 \u2344 \u2404 \u8232 \u2410 \u2414 . \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2360 \u2369 \u2333 \u2366 \u2357 \u2325 \u2379  \u2354 \u2366 \u2327 \u2367  \u2343 \u2344 \u2381 \u2351 \u2357 \u2366 \u2342 \u2404 \u8232 \u2410 \u2415 . \u2347 \u2375 \u2352 \u2367  \u2360 \u2375 \u2357 \u2366  \u2327 \u2352 \u2381 \u2344 \u2375  \u2350 \u2380 \u2325 \u2366  \u2342 \u2367 \u2344 \u2369 \u2361 \u2379 \u2354 \u2366 , \u2344 \u2350 \u2360 \u2381 \u2325 \u2366 \u2352 \u2404 \u8232 \u2411 \u2406 . \u2358 \u2369 \u2349  \u2342 \u2367 \u2344 , \u2361 \u2332 \u2369 \u2352 \u2325 \u2379  \u2342 \u2367 \u2344  \u2352 \u2366 \u2350 \u2381 \u2352 \u2379  \u2352 \u2361 \u2379 \u2360 \u2381 \u2404 \
